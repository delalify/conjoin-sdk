{
  "name": "@conjoin-cloud/sdk",
  "version": "0.0.2",
  "type": "module",
  "description": "Official TypeScript SDK for Conjoin: auth, billing, storage, messaging, relay, AI, runtime, database, and cloud, in one tree-shakeable package.",
  "author": "Delalify Engineering (https://delalify.com)",
  "license": "MIT",
  "homepage": "https://conjoin.delalify.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/delalify/conjoin-sdk.git",
    "directory": "sdks/typescript"
  },
  "bugs": {
    "url": "https://github.com/delalify/conjoin-sdk/issues"
  },
  "keywords": [
    "sdk",
    "conjoin",
    "typescript",
    "auth",
    "billing",
    "storage",
    "messaging",
    "relay",
    "ai",
    "database",
    "runtime",
    "cloud",
    "developer-platform"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "sideEffects": [
    "./dist/react/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./database": {
      "types": "./dist/database/index.d.ts",
      "import": "./dist/database/index.js",
      "require": "./dist/database/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./messaging": {
      "types": "./dist/messaging/index.d.ts",
      "import": "./dist/messaging/index.js",
      "require": "./dist/messaging/index.cjs"
    },
    "./billing": {
      "types": "./dist/billing/index.d.ts",
      "import": "./dist/billing/index.js",
      "require": "./dist/billing/index.cjs"
    },
    "./relay": {
      "types": "./dist/relay/index.d.ts",
      "import": "./dist/relay/index.js",
      "require": "./dist/relay/index.cjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js",
      "require": "./dist/ai/index.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs"
    },
    "./cloud": {
      "types": "./dist/cloud/index.d.ts",
      "import": "./dist/cloud/index.js",
      "require": "./dist/cloud/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "require": "./dist/next/index.cjs"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "import": "./dist/express/index.js",
      "require": "./dist/express/index.cjs"
    },
    "./hono": {
      "types": "./dist/hono/index.d.ts",
      "import": "./dist/hono/index.js",
      "require": "./dist/hono/index.cjs"
    },
    "./expo": {
      "types": "./dist/expo/index.d.ts",
      "import": "./dist/expo/index.js",
      "require": "./dist/expo/index.cjs"
    },
    "./react/styles.css": "./dist/react/styles.css"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@types/express": ">=4.17.25",
    "expo-secure-store": ">=13.0.2",
    "express": ">=4.22.2",
    "hono": ">=4.12.23",
    "next": ">=16.2.6",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "@types/express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.6",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "expo-secure-store": "55.0.13",
    "hono": "4.12.18",
    "next": "16.2.6",
    "openapi-typescript": "7.13.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "scripts": {
    "build": "tsup",
    "lint": "biome check src/ tests/",
    "format": "biome check --write src/ tests/",
    "typecheck": "tsc --noEmit && tsc --project tests/tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:coverage": "vitest run --config vitest.integration.config.ts --coverage",
    "test:all": "pnpm test && pnpm test:integration",
    "test:all:coverage": "pnpm test:coverage && pnpm test:integration:coverage",
    "generate": "openapi-typescript ../../spec/openapi.json -o src/generated/api-types.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-visually-hidden": "1.2.4",
    "@tanstack/query-core": "5.90.20",
    "jose": "6.2.3"
  }
}
