{
  "name": "sdk-typescript-react-core",
  "tags": ["typescript"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsup",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm biome check src/",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc --noEmit && pnpm tsc -p tsconfig.web.json",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["^build"],
      "inputs": ["default", "{workspaceRoot}/tsconfig.base.json"],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run --passWithNoTests",
        "cwd": "{projectRoot}"
      }
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["build"],
      "options": {
        "packageRoot": "{projectRoot}"
      }
    }
  }
}
