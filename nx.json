{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/pnpm-workspace.yaml"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/vitest.config.ts"
    ]
  },
  "release": {
    "groups": {
      "typescript": {
        "projects": [
          "sdk-typescript",
          "sdk-typescript-react-core",
          "sdk-typescript-react",
          "sdk-typescript-expo"
        ],
        "projectsRelationship": "fixed",
        "releaseTag": {
          "pattern": "typescript-v{version}"
        }
      }
    },
    "version": {
      "conventionalCommits": false,
      "updateDependents": "never"
    },
    "changelog": {
      "automaticFromRef": true,
      "workspaceChangelog": false,
      "projectChangelogs": false
    },
    "git": {
      "commit": true,
      "tag": true,
      "push": true,
      "commitMessage": "chore(release): {version}"
    }
  },
  "targetDefaults": {
    "generate": {
      "dependsOn": [
        "spec:validate"
      ],
      "inputs": [
        "{workspaceRoot}/spec/openapi.json",
        "{projectRoot}/codegen/**/*"
      ],
      "outputs": [
        "{projectRoot}/src/generated/**/*"
      ],
      "cache": true
    },
    "build": {
      "dependsOn": [
        "^build",
        "generate"
      ],
      "inputs": [
        "production"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true
    },
    "lint": {
      "cache": false
    },
    "test": {
      "cache": true
    },
    "format": {
      "cache": false
    }
  },
  "analytics": false
}
