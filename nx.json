{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/vitest.config.ts"
    ]
  },
  "release": {
    "projects": [
      "sdk-typescript"
    ],
    "projectsRelationship": "independent",
    "version": {
      "conventionalCommits": false,
      "updateDependents": "never"
    },
    "changelog": {
      "automaticFromRef": true,
      "workspaceChangelog": {
        "createRelease": "github"
      },
      "projectChangelogs": false
    },
    "git": {
      "commit": true,
      "tag": true,
      "push": true,
      "commitMessage": "chore(release): {projectName}@v{version}"
    },
    "releaseTag": {
      "pattern": "{projectName}@v{version}"
    }
  },
  "targetDefaults": {
    "generate": {
      "dependsOn": [
        "spec:validate"
      ],
      "inputs": [
        "{workspaceRoot}/spec/openapi.json",
        "{projectRoot}/codegen/**/*"
      ],
      "outputs": [
        "{projectRoot}/src/generated/**/*"
      ],
      "cache": true
    },
    "build": {
      "dependsOn": [
        "^build",
        "generate"
      ],
      "inputs": [
        "production"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true
    },
    "lint": {
      "cache": false
    },
    "test": {
      "cache": true
    },
    "format": {
      "cache": false
    }
  }
}
